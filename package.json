{
  "name": "byakugan",
  "version": "0.0.1",
  "description": "Dashboard to monitor AI agent processes and focus IDE windows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litencatt/byakugan"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "BYAKUGAN_DEBUG=true tsx watch src/server.ts",
    "dev:bg": "tsx watch src/server.ts > /tmp/byakugan.log 2>&1 & echo $! > /tmp/byakugan.pid && echo \"byakugan started (PID: $(cat /tmp/byakugan.pid))\"",
    "dev:stop": "kill $(cat /tmp/byakugan.pid) && rm /tmp/byakugan.pid && echo 'byakugan stopped'",
    "dev:log": "tail -f /tmp/byakugan.log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "vitest": {
    "include": ["src/**/*.test.ts"]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
