{
  "name": "byakugan",
  "version": "0.0.1",
  "description": "Dashboard to monitor AI agent processes and focus IDE windows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litencatt/byakugan"
  },
  "scripts": {
    "build": "tsc && npm run build:swift",
    "build:swift": "swift build -c release --package-path tools/focus-window",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "vitest": {
    "include": ["src/**/*.test.ts"]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
