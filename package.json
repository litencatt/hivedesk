{
  "name": "claudes-watch",
  "version": "1.0.0",
  "description": "Monitor Claude Code processes and focus VSCode windows",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "vitest": {
    "include": ["src/**/*.test.ts"]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
